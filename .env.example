# ==============================================================================
# ShowAnswer Project Environment Configuration Template
# Copy this file to '.env' and modify the values as needed.
# ==============================================================================

# --- DATABASE CONFIGURATION ---
# Connection string for PostgreSQL database
# Default assumes username 'postgres', password 'postgres', on localhost:5432 with database 'show_answer'
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/show_answer
POSTGRES_URL=postgresql://postgres:postgres@localhost:5432/show_answer
DB_PORT=5432

# --- SERVER CONFIGURATIONS ---
# Both Admin and Teacher portals run on a single unified port
ADMIN_PORT=8000
TEACHER_PORT=8000

# --- LOCAL PORTAL LINKS ---
# Admin Portal / Classroom Hub (Manage roster, generate student polling cards)
ADMIN_LINK=http://localhost:8000/admin/login.html

# Teacher Portal (Configure quiz questions, scan response sheets, view grade analytics)
TEACHER_LINK=http://localhost:8000/teacher/login.html

# Manage Teachers Page (Add / delete teacher accounts — Admin only)
MANAGE_TEACHERS_LINK=http://localhost:8000/admin/manage_teachers.html

# --- DEFAULT CREDENTIALS (change after first login) ---
# Admin login:   username=admin    password=admin123
# Teacher login: username=teacher  password=teacher123
# OTP Bypass Passcode (for local testing): 123456
